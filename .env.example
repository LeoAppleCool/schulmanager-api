SM_BACKEND=mock

SM_JWT_SECRET=change-me
SM_ACCESS_TOKEN_TTL_MINUTES=30
SM_REFRESH_TOKEN_TTL_DAYS=14
SM_ADMIN_EMAILS_CSV=
SM_VIEWER_EMAILS_CSV=

# Timezone the school's wall-clock lesson/event times are in (ICS export + parsing).
SM_SCHOOL_TIMEZONE=Europe/Berlin

SM_CACHE_ENABLED=true
SM_CACHE_BACKEND=sqlite
SM_CACHE_DB_PATH=data/cache.sqlite3
SM_CACHE_TTL_SCHEDULE_SECONDS=120
SM_CACHE_TTL_HOMEWORK_SECONDS=90
SM_CACHE_TTL_EXAMS_SECONDS=180
SM_CACHE_TTL_GRADES_SECONDS=180
SM_CACHE_TTL_EVENTS_SECONDS=180
SM_CACHE_TTL_ABSENCES_SECONDS=180
SM_CACHE_TTL_MESSAGES_SECONDS=60

SM_RATE_LIMIT_ENABLED=true
SM_RATE_LIMIT_REQUESTS=120
SM_RATE_LIMIT_WINDOW_SECONDS=60

SM_WEBHOOKS_ENABLED=true
SM_WEBHOOK_TIMEOUT_SECONDS=8
SM_WEBHOOK_HMAC_SECRET=change-webhook-secret

# The 'selenium' backend logs in over HTTP (get-salt + login); the headless-browser step is an
# optional double-check, OFF by default. Enable only if you also install Chrome + chromedriver.
SM_SELENIUM_HEADLESS=true
SM_SELENIUM_DRIVER_PATH=
SM_SELENIUM_LOGIN_TIMEOUT_SECONDS=25
SM_SELENIUM_REQUIRE_BROWSER=false
# Fallback bundleVersion (its content is not validated by the server); auto-discovered + cached.
SM_SELENIUM_BUNDLE_VERSION=42424242424242424242
SM_SELENIUM_BUNDLE_CACHE_TTL_SECONDS=3600
SM_SELENIUM_TERM_ID=28592

SM_LOG_FORMAT=text
SM_LOG_LEVEL=INFO
SM_METRICS_REQUIRE_AUTH=false
